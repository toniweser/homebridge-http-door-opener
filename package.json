{
  "private": false,
  "displayName": "HTTP door opener",
  "name": "homebridge-http-button",
  "version": "2.0.1",
  "description": "A small plugin to open the front door of an apartment building using an ESP32",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/toniweser/homebridge-http-door-opener.git"
  },
  "bugs": {
    "url": "https://github.com/toniweser/homebridge-http-door-opener/issues"
  },
  "engines": {
    "node": ">=20",
    "homebridge": ">=1.3.5"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json"
  ],
  "scripts": {
    "lint": "biome check src",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "door-opener",
    "ESP-32",
    "door",
    "HTTP"
  ],
  "dependencies": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^25.6.0",
    "homebridge": "^1.11.4",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
